---
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marketing Copilot - Gemini</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f2f7ff;
        --panel: #ffffff;
        --ink: #112a47;
        --muted: #536a84;
        --brand: #1557dd;
        --brand-soft: #dfebff;
        --accent: #f97316;
        --border: #d5e2f3;
        --danger: #b4233a;
        --ok: #0f8a4c;
        --shadow: 0 14px 34px rgba(17, 42, 71, 0.08);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        color: var(--ink);
        background: radial-gradient(circle at 10% 0%, #d8e7ff 0, #f2f7ff 44%, #edf4ff 100%);
        font-family: "Manrope", "Segoe UI", sans-serif;
      }

      main {
        max-width: 1220px;
        margin: 0 auto;
        padding: 1rem;
        display: grid;
        gap: 1rem;
      }

      .skip-link {
        position: absolute;
        left: 1rem;
        top: -100px;
        background: #0a3d9b;
        color: #fff;
        padding: 0.55rem 0.8rem;
        border-radius: 10px;
        text-decoration: none;
        z-index: 999;
      }

      .skip-link:focus { top: 1rem; }

      .hero {
        background: linear-gradient(145deg, #0f2e54 0%, #184680 65%, #1f5ea7 100%);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: var(--shadow);
        color: #fff;
        padding: 1rem;
      }

      .hero-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
      }

      h1 {
        margin: 0;
        font-family: "Space Grotesk", "Manrope", sans-serif;
        font-size: 1.45rem;
      }

      .subtitle {
        margin: 0.45rem 0 0;
        color: #d4e6ff;
        max-width: 74ch;
      }

      .status { color: var(--muted); font-size: 0.9rem; }
      .error { color: var(--danger); }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(17, 42, 71, 0.05);
        padding: 0.95rem;
      }

      .panel h2 {
        margin: 0 0 0.7rem;
        font-family: "Space Grotesk", "Manrope", sans-serif;
        font-size: 1.04rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid transparent;
        padding: 0.28rem 0.62rem;
        font-size: 0.78rem;
        font-weight: 700;
      }

      .badge.warn { background: #fff4d9; color: #8a5d00; border-color: #f3d58e; }
      .badge.ok { background: #e3f9ed; color: var(--ok); border-color: #9fe1bf; }
      .badge.error { background: #ffe8ec; color: #9f1f37; border-color: #ffc5cf; }

      .row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .start-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      input[type="file"], input[type="text"], select, button { font: inherit; }

      input[type="text"], select {
        border: 1px solid var(--border);
        border-radius: 11px;
        padding: 0.6rem 0.72rem;
        background: #fff;
        color: var(--ink);
      }

      button {
        border: 0;
        border-radius: 11px;
        padding: 0.6rem 0.86rem;
        background: var(--brand);
        color: #fff;
        font-weight: 700;
        cursor: pointer;
      }

      button.secondary {
        background: var(--brand-soft);
        color: #1a4fb8;
      }

      button:disabled { opacity: 0.56; cursor: not-allowed; }

      button:focus-visible,
      input:focus-visible,
      select:focus-visible,
      a:focus-visible {
        outline: 3px solid #1f62e1;
        outline-offset: 2px;
      }

      .chat-box {
        max-height: 320px;
        overflow: auto;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.7rem;
        background: #f8fbff;
      }

      .msg {
        margin: 0.5rem 0;
        padding: 0.62rem 0.68rem;
        border-radius: 10px;
        line-height: 1.45;
        white-space: pre-wrap;
      }

      .msg.user { background: #dce9ff; }
      .msg.bot { background: #e9f4ff; }

      .chips {
        margin-top: 0.7rem;
        display: flex;
        gap: 0.42rem;
        flex-wrap: wrap;
      }

      .chips button {
        background: #eaf1ff;
        color: #1646aa;
        padding: 0.43rem 0.62rem;
        font-size: 0.82rem;
      }

      .workspace-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.8rem;
        flex-wrap: wrap;
      }

      .tabs {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }

      .tab-panel {
        margin-top: 0.85rem;
      }

      .kpi-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .kpi-card {
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.66rem;
        background: #f8fbff;
      }

      .kpi-card.primary {
        grid-column: span 2;
        background: linear-gradient(135deg, #e7f0ff 0%, #dce9ff 100%);
      }

      .kpi-label { font-size: 0.8rem; color: #3f5976; }
      .kpi-value { margin-top: 0.25rem; font-size: 1.3rem; font-weight: 800; }

      .charts-grid {
        margin-top: 0.8rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
      }

      .chart-card {
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.68rem;
        background: #f4f9ff;
      }

      .chart-card h3 { margin: 0; font-size: 0.95rem; }
      .chart-card p { margin: 0.38rem 0 0.6rem; color: var(--muted); font-size: 0.84rem; }
      .chart-canvas { width: 100%; min-height: 270px; }

      .interpretation {
        display: grid;
        gap: 0.66rem;
      }

      .interpretation .block {
        border: 1px solid var(--border);
        border-radius: 11px;
        padding: 0.66rem;
        background: #f8fbff;
      }

      .interpretation .block h3 { margin: 0 0 0.35rem; font-size: 0.93rem; }
      .interpretation ul { margin: 0; padding-left: 1rem; }

      .tables-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1fr;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }

      th, td {
        border-bottom: 1px solid var(--border);
        padding: 0.5rem;
        text-align: left;
      }

      .is-hidden { display: none !important; }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (min-width: 960px) {
        .start-grid { grid-template-columns: 1fr 1.08fr; }
        .kpi-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
        .kpi-card.primary { grid-column: span 5; }
        .charts-grid { grid-template-columns: 1fr 1fr; }
        .chart-card.wide { grid-column: span 2; }
        .tables-grid { grid-template-columns: 1fr 1fr; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#appMain">Saltar al contenido principal</a>
    <main id="appMain" tabindex="-1">
      <section class="hero">
        <div class="hero-head">
          <div>
            <h1>Marketing Copilot - Gemini</h1>
            <p class="subtitle">Sube tu CSV de comportamiento y consulta insights accionables para marketing y growth.</p>
          </div>
          <div class="row" aria-live="polite">
            <span id="geminiStatusBadge" class="badge warn">Validando Gemini...</span>
            <button id="refreshGeminiHealthBtn" class="secondary">Revalidar</button>
          </div>
        </div>
        <p id="geminiStatusText" class="status">Comprobando API key y conectividad...</p>
      </section>

      <section class="start-grid">
        <article class="panel">
          <h2>Subida de CSV</h2>
          <div class="row">
            <label for="csvFile" class="sr-only">Seleccionar archivo CSV</label>
            <input id="csvFile" type="file" accept=".csv" />
            <button id="uploadBtn">Cargar y Procesar</button>
            <button id="refreshBtn" class="secondary is-hidden">Actualizar</button>
          </div>
          <div id="advancedDatasetRow" class="row is-hidden" style="margin-top: 0.72rem;">
            <label for="datasetSelect" class="sr-only">Seleccionar dataset activo</label>
            <select id="datasetSelect" style="min-width: 280px;"></select>
            <button id="activateDatasetBtn" class="secondary">Activar</button>
            <button id="deleteDatasetBtn" class="secondary">Eliminar</button>
            <button id="cleanupDatasetsBtn" class="secondary">Limpiar antiguos</button>
          </div>
          <p id="uploadStatus" class="status" aria-live="polite">Sube un archivo CSV para empezar.</p>
        </article>

        <article class="panel">
          <h2>Copiloto de Marketing</h2>
          <div id="chatBox" class="chat-box" role="log" aria-live="polite" aria-relevant="additions text"></div>
          <div class="row" style="margin-top: 0.75rem;">
            <label for="chatInput" class="sr-only">Mensaje para Gemini</label>
            <input id="chatInput" type="text" placeholder="Ejemplo: ¿Que accion priorizo para mejorar conversion?" style="flex: 1; min-width: 240px;" />
            <button id="chatBtn">Preguntar</button>
          </div>
          <div id="quickQuestions" class="chips">
            <button data-question="Cuales son las principales oportunidades de conversion para este dataset?">Oportunidades</button>
            <button data-question="En que parte del embudo estamos perdiendo mas usuarios y que accion recomiendas?">Fuga embudo</button>
            <button data-question="Dame un plan de accion de 7 dias para mejorar leads con estos datos.">Plan 7 dias</button>
          </div>
          <p id="chatStatus" class="status" aria-live="polite"></p>
          <p id="chatDataset" class="status">Dataset activo para chat: -</p>
        </article>
      </section>

      <section id="dataWorkspace" class="panel is-hidden">
        <div class="workspace-head">
          <h2>Datos procesados</h2>
          <div class="tabs" role="tablist" aria-label="Vistas de datos">
            <button id="tabOverviewBtn" role="tab" aria-selected="true">Resumen</button>
            <button id="tabInsightsBtn" role="tab" aria-selected="false" class="secondary">Insights</button>
            <button id="tabTablesBtn" role="tab" aria-selected="false" class="secondary">Tablas</button>
          </div>
        </div>

        <section id="tabOverview" class="tab-panel">
          <div class="row" style="margin-bottom: 0.7rem;">
            <label for="objectiveSelect" class="status">Objetivo:</label>
            <select id="objectiveSelect">
              <option value="leads">Generacion de leads</option>
              <option value="retencion">Retencion</option>
              <option value="engagement">Engagement</option>
            </select>
            <button id="exportSummaryBtn" class="secondary">Exportar resumen CSV</button>
          </div>

          <div class="kpi-grid">
            <article class="kpi-card primary">
              <div class="kpi-label">Sesiones Totales</div>
              <div class="kpi-value" id="kpiSessions">-</div>
            </article>
            <article class="kpi-card">
              <div class="kpi-label">Duracion Promedio (seg)</div>
              <div class="kpi-value" id="kpiDuration">-</div>
            </article>
            <article class="kpi-card">
              <div class="kpi-label">Abandono Rapido (%)</div>
              <div class="kpi-value" id="kpiQuickExit">-</div>
            </article>
            <article class="kpi-card">
              <div class="kpi-label">Intencion de Conversion (%)</div>
              <div class="kpi-value" id="kpiIntentPct">-</div>
            </article>
            <article class="kpi-card">
              <div class="kpi-label">High Intent (%)</div>
              <div class="kpi-value" id="kpiHighIntentPct">-</div>
            </article>
          </div>

          <div class="charts-grid">
            <article class="chart-card">
              <h3>Top Pages por participacion</h3>
              <p>Detecta donde concentrar experimentos de conversion.</p>
              <div id="topPagesChart" class="chart-canvas" role="img" aria-label="Grafica top pages"></div>
            </article>
            <article class="chart-card">
              <h3>Exit Rate critico</h3>
              <p>Identifica puntos de fuga por pagina.</p>
              <div id="exitRateChart" class="chart-canvas" role="img" aria-label="Grafica exit rate"></div>
            </article>
            <article class="chart-card wide">
              <h3>Embudo de Marketing</h3>
              <p>Awareness -> Evaluation -> Conversion.</p>
              <div id="funnelChart" class="chart-canvas" role="img" aria-label="Grafica embudo"></div>
            </article>
          </div>
        </section>

        <section id="tabInsights" class="tab-panel is-hidden">
          <div id="insights"></div>
        </section>

        <section id="tabTables" class="tab-panel is-hidden">
          <div class="tables-grid">
            <article class="panel">
              <h2>Top Pages</h2>
              <table id="topPagesTable">
                <caption class="sr-only">Paginas con mayor trafico</caption>
                <thead>
                  <tr><th scope="col">Pagina</th><th scope="col">Sesiones</th><th scope="col">%</th></tr>
                </thead>
                <tbody></tbody>
              </table>
            </article>
            <article class="panel">
              <h2>Exit Rate</h2>
              <table id="exitRateTable">
                <caption class="sr-only">Tasa de salida por pagina</caption>
                <thead>
                  <tr><th scope="col">Pagina</th><th scope="col">Exits</th><th scope="col">Tasa (%)</th></tr>
                </thead>
                <tbody></tbody>
              </table>
            </article>
          </div>
          <article class="panel" style="margin-top: 0.9rem;">
            <h2>Flujos mas frecuentes</h2>
            <table id="flowsTable">
              <caption class="sr-only">Flujos de navegacion mas frecuentes</caption>
              <thead>
                <tr><th scope="col">Desde</th><th scope="col">Hacia</th><th scope="col">Conteo</th></tr>
              </thead>
              <tbody></tbody>
            </table>
          </article>
        </section>
      </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js" defer></script>
    <script type="module" src="/js/dashboard/main.js"></script>
  </body>
</html>
